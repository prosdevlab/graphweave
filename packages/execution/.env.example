# Required: at least one LLM provider
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=10

# Auth — bootstrap admin key via CLI (run from repo root):
#   docker compose -f docker-compose.dev.yml exec execution uv run python -m app.cli create-key --name admin --scopes all
# Then copy the printed key into packages/canvas/.env as VITE_API_KEY
